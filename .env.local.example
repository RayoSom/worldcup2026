# IA — Obtener en https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_KEY

# Código de acceso al módulo Predictor IA (compártelo con usuarios de confianza)
ACCESS_CODE=tu-codigo-secreto

# Resultados reales — Registrar en https://www.football-data.org/client/register (gratis)
FOOTBALL_DATA_API_KEY=REPLACE_WITH_YOUR_KEY

# Feature flags — cambiar a false para desactivar un módulo
NEXT_PUBLIC_TORNEO_ENABLED=true
NEXT_PUBLIC_PARTIDO_ENABLED=true
NEXT_PUBLIC_PREDICTOR_ENABLED=true
NEXT_PUBLIC_PREDICTOR_PANEL_ENABLED=true
